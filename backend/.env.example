# ─────────────────────────────────────────────
# 3D Café — Backend Environment Configuration
# Copy this file to .env and fill in values.
# ALL optional integrations degrade gracefully
# when their credentials are absent.
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# ── MongoDB (required) ─────────────────────
MONGODB_URI=mongodb://localhost:27017/cafe_db

# ── JWT (required) ─────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRE=30d

# ── Google OAuth (optional) ────────────────
# Leave blank to disable Google Sign-In.
# Backend will boot normally without these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Cloudinary (optional) ──────────────────
# Leave blank to disable image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe (optional) ──────────────────────
# Leave blank to disable payment processing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email / SMTP (optional) ────────────────
# Leave blank to disable transactional email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@cafe3d.com
FROM_NAME=3D Café

# ── Frontend URL ───────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Session ────────────────────────────────
SESSION_SECRET=your_session_secret_here
